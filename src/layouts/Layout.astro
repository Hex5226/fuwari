/* 按钮悬停时渐变背景（与主题色呼应） */
.btn-plain:hover,
.btn-regular:hover,
button:hover:not(.btn-plain):not(.btn-regular) {
  background-image: linear-gradient(135deg, rgba(201,126,90,0.2), rgba(255,160,100,0.2)) !important;
  background-color: transparent !important;

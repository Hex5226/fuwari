---
import "@fontsource/roboto/400.css";
import "@fontsource/roboto/500.css";
import "@fontsource/roboto/700.css";

import ConfigCarrier from "@components/ConfigCarrier.astro";
import { profileConfig, siteConfig } from "@/config";
import {
	AUTO_MODE,
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	BANNER_HEIGHT_HOME,
	DARK_MODE,
	DEFAULT_THEME,
	LIGHT_MODE,
	PAGE_WIDTH,
} from "../constants/constants";
import { defaultFavicons } from "../constants/icon";
import type { Favicon } from "../types/config";
import { pathsEqual, url } from "../utils/url-utils";
import "katex/dist/katex.css";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
}

let { title, banner, description, lang, setOGTypeArticle } = Astro.props;

// apply a class to the body element to decide the height of the banner, only used for initial page load
// Swup can update the body for each page visit, but it's after the page transition, causing a delay for banner height change
// so use Swup hooks instead to change the height immediately when a link is clicked
const isHomePage = pathsEqual(Astro.url.pathname, url("/"));

// defines global css variables
// why doing this in Layout instead of GlobalStyles: https://github.com/withastro/astro/issues/6728#issuecomment-1502203757
const configHue = siteConfig.themeColor.hue;
if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = siteConfig.banner.src;
}

// TODO don't use post cover as banner for now
banner = siteConfig.banner.src;

const enableBanner = siteConfig.banner.enable;

let pageTitle: string;
if (title) {
	pageTitle = `${title} - ${siteConfig.title}`;
} else {
	pageTitle = `${siteConfig.title} - ${siteConfig.subtitle}`;
}

const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

// const siteLang = siteConfig.lang.replace('_', '-')
if (!lang) {
	lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");

const bannerOffsetByPosition = {
	top: `${BANNER_HEIGHT_EXTEND}vh`,
	center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
	bottom: "0",
};
const bannerOffset =
	bannerOffsetByPosition[siteConfig.banner.position || "center"];
---

<!DOCTYPE html>
<html lang={siteLang} class="bg-[var(--page-bg)] transition text-[14px] md:text-[16px]"
	  data-overlayscrollbars-initialize
>
<head>
<!-- 预加载关键资源 -->
<link rel="preload" as="image" href="/bg.jpg" fetchpriority="high">
<link rel="preload" as="font" type="font/woff2" href="/fonts/inter.woff2" crossorigin>
	<title>{pageTitle}</title>
	<meta charset="UTF-8" />
	<meta name="description" content={description || pageTitle}>
	<meta name="author" content={profileConfig.name}>

	<meta property="og:site_name" content={siteConfig.title}>
	<meta property="og:url" content={Astro.url}>
	<meta property="og:title" content={pageTitle}>
	<meta property="og:description" content={description || pageTitle}>
	{setOGTypeArticle ? (
		<meta property="og:type" content="article" />
	) : (
		<meta property="og:type" content="website" />
	)}

	<meta name="twitter:card" content="summary_large_image">
	<meta property="twitter:url" content={Astro.url}>
	<meta name="twitter:title" content={pageTitle}>
	<meta name="twitter:description" content={description || pageTitle}>

	<meta name="viewport" content="width=device-width" />
	<meta name="generator" content={Astro.generator} />
	{favicons.map(favicon => (
		<link rel="icon"
			  href={favicon.src.startsWith('/') ? url(favicon.src) : favicon.src}
			  sizes={favicon.sizes}
			  media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
		/>
	))}

	<!-- Set the theme before the page is rendered to avoid a flash -->
	<script is:inline define:vars={{DEFAULT_THEME, LIGHT_MODE, DARK_MODE, AUTO_MODE, BANNER_HEIGHT_EXTEND, PAGE_WIDTH, configHue}}>
		// Load the theme from local storage
		const theme = localStorage.getItem('theme') || DEFAULT_THEME;
		switch (theme) {
			case LIGHT_MODE:
				document.documentElement.classList.remove('dark');
				break
			case DARK_MODE:
				document.documentElement.classList.add('dark');
				break
			case AUTO_MODE:
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
		}

		// Load the hue from local storage
		const hue = localStorage.getItem('hue') || configHue;
		document.documentElement.style.setProperty('--hue', hue);

		// calculate the --banner-height-extend, which needs to be a multiple of 4 to avoid blurry text
		let offset = Math.floor(window.innerHeight * (BANNER_HEIGHT_EXTEND / 100));
		offset = offset - offset % 4;
		document.documentElement.style.setProperty('--banner-height-extend', `${offset}px`);
	</script>

	<style define:vars={{
		configHue,
		'page-width': `${PAGE_WIDTH}rem`,
	}}></style>  <!-- 这个 style 块可能是空的，可以保留 -->

	<slot name="head"></slot>

	<link rel="alternate" type="application/rss+xml" title={profileConfig.name} href={`${Astro.site}rss.xml`}/>
</head>
	<body class=" min-h-screen transition " class:list={[{"lg:is-home": isHomePage, "enable-banner": enableBanner}]}
		  data-overlayscrollbars-initialize
	>
<script>

  // 平滑滚动：为所有内部锚点链接添加平滑滚动效果
  document.addEventListener('click', (e) => {
    const link = e.target.closest('a');
    if (!link) return;
    const href = link.getAttribute('href');
    // 只处理当前页面内的锚点（#开头且不是纯#，且不是外部链接）
    if (href && href.startsWith('#') && href !== '#') {
      const targetId = href.slice(1);
      const targetElement = document.getElementById(targetId);
      if (targetElement) {
        e.preventDefault();
        targetElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
        // 可选：更新 URL 哈希（不触发滚动）
        history.pushState(null, null, href);
      }
    }
  });

(function() {
  // 检查是否已经显示过启动动效（当前会话中）
  if (sessionStorage.getItem('splashShown')) {
    return;
  }
  sessionStorage.setItem('splashShown', 'true');

  // 添加动画关键帧（避免重复添加）
  if (!document.getElementById('splash-anim-styles')) {
    const style = document.createElement('style');
    style.id = 'splash-anim-styles';
    style.textContent = `
      @keyframes bounceShake {
        0% { transform: scale(0.8) translateY(0); opacity: 0; }
        30% { transform: scale(1.2) translateY(-10px); opacity: 1; }
        60% { transform: scale(1) translateY(5px); }
        80% { transform: translateY(-3px); }
        100% { transform: translateY(0); }
      }
      @keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(20px); }
        100% { opacity: 1; transform: translateY(0); }
      }
    `;
    document.head.appendChild(style);
  }

  const splash = document.createElement('div');
  splash.id = 'splash-screen';
  splash.style.cssText = `
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #c97e5a;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 1;
    transition: opacity 1.2s ease-out;
    pointer-events: none;
  `;
  const text = document.createElement('span');
  text.style.cssText = `
    font-size: 6rem;
    font-weight: bold;
    color: white;
    font-family: 'Inter', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', 'Helvetica Neue', sans-serif;
    letter-spacing: 0.1em;
    text-shadow: 2px 2px 12px rgba(0, 0, 0, 0.5);
    animation: bounceShake 0.8s ease-out;
    margin-bottom: 2rem;
  `;
  text.textContent = '-_Hex';
  const subText = document.createElement('span');
  subText.style.cssText = `
    font-size: 2rem;
    font-weight: normal;
    color: white;
    font-family: 'Inter', 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', 'Helvetica Neue', sans-serif;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.3s forwards;
  `;
  subText.textContent = '技术小站';
  splash.appendChild(text);
  splash.appendChild(subText);
  document.body.appendChild(splash);

  window.addEventListener('load', () => {
    setTimeout(() => {
      splash.style.opacity = '0';
      splash.style.transition = 'opacity 0.8s ease-out';
      splash.addEventListener('transitionend', () => splash.remove(), { once: true });
    }, 1500);
  });
})();
</script>
		<ConfigCarrier></ConfigCarrier>
		<slot />

		<!-- increase the page height during page transition to prevent the scrolling animation from jumping -->
		<div id="page-height-extend" class="hidden h-[300vh]"></div>
<script>
  // 为所有图片添加懒加载属性（兼容性良好）
  document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll('img');
    images.forEach(img => {
      if (!img.hasAttribute('loading')) {
        img.setAttribute('loading', 'lazy');
      }
    });
  });
</script>
	</body>
</html>

<style is:global define:vars={{
	bannerOffset,
	'banner-height-home': `${BANNER_HEIGHT_HOME}vh`,
	'banner-height': `${BANNER_HEIGHT}vh`,
}}>
@tailwind components;
@layer components {
	.enable-banner.is-home #banner-wrapper {
		@apply h-[var(--banner-height-home)] translate-y-[var(--banner-height-extend)]
	}
	.enable-banner #banner-wrapper {
		@apply h-[var(--banner-height-home)]
	}

	.enable-banner.is-home #banner {
		@apply h-[var(--banner-height-home)] translate-y-0
	}
	.enable-banner #banner {
		@apply h-[var(--banner-height-home)] translate-y-[var(--bannerOffset)]
	}
	.enable-banner.is-home #main-grid {
		@apply translate-y-[var(--banner-height-extend)];
	}
	.enable-banner #top-row {
		@apply h-[calc(var(--banner-height-home)_-_4.5rem)] transition-all duration-300
	}
	.enable-banner.is-home #sidebar-sticky {
		@apply top-[calc(1rem_-_var(--banner-height-extend))]
	}
	.navbar-hidden {
		@apply opacity-0 -translate-y-16
	}
}

:root {
  --primary: #c97e5a !important;
    --link-hover: #c97e5a !important;
  --btn-plain-bg-hover: rgba(255, 255, 255, 0.2) !important;  /* 保持半透明，不干扰颜色 */
}

body {
  background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('/bg.jpg');
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  background-repeat: no-repeat;
}

/* 侧边栏内所有卡片（分类、标签） */
#sidebar-sticky .card-base {
  background-color: rgba(0, 0, 0, 0.6) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
}

/* 导航栏卡片 */
#navbar .card-base {
  background-color: rgba(0, 0, 0, 0.6) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
}

/* 文章卡片（如果有） */
.post-card, .article-card {
  background-color: rgba(0, 0, 0, 0.6) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
}

/* 头像框（特殊处理） */
#sidebar > .flex.flex-col > .card-base:first-child {
  background-color: rgba(0, 0, 0, 0.6) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
}
#sidebar > .flex.flex-col > .card-base:first-child,
#sidebar > .flex.flex-col > .card-base:first-child * {
  color: #ffffff !important;
}
#sidebar > .flex.flex-col > .card-base:first-child a {
  color: var(--primary) !important;
}

/* 分割线 */
hr, .border-t, .border-b, .border-dashed {
  border-color: rgba(255, 255, 255, 0.2) !important;
}

.btn-plain,
.btn-regular {
  background-color: rgba(255, 255, 255, 0.1) !important;
  border: 1px solid rgba(255, 255, 255, 0.2) !important;
}
.btn-plain:hover,
.btn-regular:hover {
  background-color: rgba(255, 255, 255, 0.2) !important;
}

/* 1. 修复“标签”标题文字颜色（与“分类”保持一致） */
#sidebar-sticky widget-layout[data-id="tags"] .font-bold {
  color: #ffffff !important;
}

/* 2. 导航栏文字“主页”“归档”改为白色 */
#navbar .btn-plain {
  color: #ffffff !important;
}
/* 导航栏按钮（搜索、调色板、主题切换、菜单）内的图标改为白色 */
#navbar button svg,
#navbar .btn-plain svg {
  color: #ffffff !important;
}
/* 导航栏右侧的显示设置按钮（调色板图标） */
#display-settings-switch svg {
  color: #ffffff !important;
}
/* 导航栏的主题切换按钮内的图标（三个不同状态） */
#scheme-switch svg {
  color: #ffffff !important;
}

/* 3. 头像框内 Steam/GitHub 按钮背景半透明（覆盖原 oklch 背景） */
#sidebar .btn-regular {
  background-color: rgba(255, 255, 255, 0.1) !important;
  border: 1px solid rgba(255, 255, 255, 0.2) !important;
}
#sidebar .btn-regular:hover {
  background-color: rgba(255, 255, 255, 0.2) !important;
}

/* 搜索框（桌面端） */
#search-bar {
  background-color: rgba(0, 0, 0, 0.4) !important;
  border: 1px solid rgba(255, 255, 255, 0.3) !important;
  border-radius: 0.5rem;
}
#search-bar input {
  background: transparent !important;
  color: #ffffff !important;
}
#search-bar input::placeholder {
  color: rgba(255, 255, 255, 0.6) !important;
}
#search-bar svg {
  color: rgba(255, 255, 255, 0.8) !important;
}

/* 搜索弹出面板 */
#search-panel {
  background-color: rgba(0, 0, 0, 0.8) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.2) !important;
}
#search-bar-inside {
  background-color: rgba(0, 0, 0, 0.6) !important;
  border: 1px solid rgba(255, 255, 255, 0.3) !important;
  border-radius: 0.5rem;
}
#search-bar-inside input {
  background: transparent !important;
  color: #ffffff !important;
}
#search-bar-inside input::placeholder {
  color: rgba(255, 255, 255, 0.6) !important;
}
#search-bar-inside svg {
  color: rgba(255, 255, 255, 0.8) !important;
}

/* 搜索面板整体背景优化 */
#search-panel {
  background-color: rgba(0, 0, 0, 0.8) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
}

/* 搜索结果文字颜色 */
#search-panel .pagefind-ui__result,
#search-panel .pagefind-ui__result * {
  color: #ffffff !important;
}

/* 搜索结果链接颜色（保持主题色） */
#search-panel .pagefind-ui__result a {
  color: var(--primary) !important;
}

/* 搜索结果高亮部分（mark） */
#search-panel .pagefind-ui__result mark {
  background-color: rgba(255, 255, 255, 0.2) !important;
  color: #ffffff !important;
}

/* 鼠标悬停时搜索结果项背景 */
#search-panel .pagefind-ui__result:hover {
  background-color: rgba(255, 255, 255, 0.1) !important;
}

/* 搜索面板内的结果链接 */
#search-panel a {
  background-color: rgba(0, 0, 0, 0.6) !important;
  border: 1px solid rgba(255, 255, 255, 0.2) !important;
  border-radius: 0.75rem; /* 与 rounded-xl 匹配 */
  margin-top: 0.5rem;
  display: block;
}

#search-panel a:first-of-type {
  margin-top: 0.5rem;
}
#search-panel a:not(:first-of-type) {
  margin-top: 0.5rem;
}

/* 结果内所有文字默认白色 */
#search-panel a,
#search-panel a * {
  color: #ffffff !important;
}

/* 标题保持主题色（可选） */
#search-panel a .font-bold {
  color: var(--primary) !important;
}

/* 悬停时背景加深，文字变为主题色（标题已主题色不变） */
#search-panel a:hover {
  background-color: rgba(255, 255, 255, 0.1) !important;
}
#search-panel a:hover * {
  color: #ffffff !important;
}
#search-panel a:hover .font-bold {
  color: var(--primary) !important;
}

/* 高亮 mark 样式 */
#search-panel mark {
  background-color: rgba(255, 255, 255, 0.2) !important;
  color: #ffffff !important;
  padding: 0 0.2rem;
  border-radius: 0.25rem;
}

/* ========== 分页导航样式（上一页/下一页按钮 & 页码数字） ========== */
/* 1. 上一页/下一页按钮背景半透明毛玻璃 */
.flex.flex-row.gap-3.justify-center a.btn-card {
  background-color: rgba(0, 0, 0, 0.6) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.2) !important;
  border-radius: 0.5rem !important;
  color: #ffffff !important;
}
/* 按钮内的箭头图标颜色改为白色（覆盖主题色） */
.flex.flex-row.gap-3.justify-center a.btn-card svg {
  color: #ffffff !important;
}

/* 悬停效果：背景变亮，箭头变主题色 */
.flex.flex-row.gap-3.justify-center a.btn-card:hover {
  background-color: rgba(255, 255, 255, 0.2) !important;
  border-color: rgba(255, 255, 255, 0.4) !important;
}
.flex.flex-row.gap-3.justify-center a.btn-card:hover svg {
  color: var(--primary) !important;
}

/* 禁用状态（如第一页时上一页不可点） */
.flex.flex-row.gap-3.justify-center a.btn-card.disabled {
  opacity: 0.5 !important;
  cursor: not-allowed !important;
}
.flex.flex-row.gap-3.justify-center a.btn-card.disabled:hover {
  background-color: rgba(0, 0, 0, 0.6) !important;
  border-color: rgba(255, 255, 255, 0.2) !important;
}
.flex.flex-row.gap-3.justify-center a.btn-card.disabled:hover svg {
  color: #ffffff !important;
}

/* 2. 页码区域整体背景半透明毛玻璃 */
.flex.flex-row.gap-3.justify-center > div:has(.bg-\[var\(--card-bg\)\]) {
  background-color: rgba(0, 0, 0, 0.6) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 0.5rem !important;
  overflow: hidden;
}

/* 页码数字文字颜色改为白色（非当前页） */
.flex.flex-row.gap-3.justify-center .text-neutral-700.dark\:text-neutral-300 {
  color: #ffffff !important;
}

/* 当前页码数字（背景为主题色，文字白色）保持不变，但确保背景不透明 */
.flex.flex-row.gap-3.justify-center .bg-\[var\(--primary\)\] {
  background-color: var(--primary) !important;
  color: #ffffff !important;
}

/* 将特定分隔元素背景设为透明 */
.transition.flex.flex-col.rounded-\[var\(--radius-large\)\].bg-\[var\(--card-bg\)\].py-1.md\:py-0.md\:bg-transparent.md\:gap-4.mb-4 {
  background-color: transparent !important;
}

html {
  background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('/bg.jpg');
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  background-repeat: no-repeat;
}
body {
  background-color: transparent !important;
}

/* 文章列表卡片毛玻璃 */
main .card-base {
  background-color: rgba(0, 0, 0, 0.6) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
}

/* 卡片内文字颜色（日期、分类、标签、字数等） */
main .card-base .text-neutral-500,
main .card-base .text-50,
main .card-base .text-black\/30,
main .card-base .text-white\/30,
main .card-base .text-sm {
  color: #ffffff !important;
}

/* 卡片内链接（分类、标签）颜色 */
main .card-base .link-lg {
  color: #ffffff !important;
}
main .card-base .link-lg:hover {
  color: var(--primary) !important;
}

/* 卡片内分割线（斜杠）颜色 */
main .card-base .mx-1\.5 {
  color: rgba(255, 255, 255, 0.3) !important;
}

/* 文章卡片标题链接默认白色 */
main .card-base a[href^="/posts/"] {
  color: #ffffff !important;
}
/* 标题右侧的箭头图标默认白色 */
main .card-base a[href^="/posts/"] svg {
  color: #ffffff !important;
}
/* 悬停时标题文字和箭头变主题色 */
main .card-base a[href^="/posts/"]:hover,
main .card-base a[href^="/posts/"]:hover svg {
  color: var(--primary) !important;
}

/* 文章卡片内的阅读更多按钮样式（btn-card） */
main .btn-card {
  background-color: rgba(0, 0, 0, 0.6) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 1rem !important;
}

/* 文字默认白色 */
main .btn-card .overflow-ellipsis {
  color: #ffffff !important;
}

/* 箭头默认白色 */
main .btn-card svg {
  color: #ffffff !important;
}

